# ─── Backend Environment Template ────────────────────────────────────────────
# Copy to backend/.env for local development

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default database (bundled e-commerce demo)
DATABASE_URL=postgresql://nl2sql:nl2sql_secret@localhost:5432/ecommerce

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_data

# Agent settings
MAX_RETRIES=3
LLM_TEMPERATURE=0.0

# Safety — set to "false" ONLY in development for testing dangerous queries
SQL_SAFETY_ENABLED=true

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
