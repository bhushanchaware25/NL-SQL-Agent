# ─── NL2SQL Agent — Root Environment Template ───────────────────────────────
# Copy this file to .env and fill in your values.
# The docker-compose.yml reads from this file automatically.

# OpenRouter API Key (get yours at https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default LLM model via OpenRouter
OPENROUTER_MODEL=openrouter/auto

# PostgreSQL (used by Docker Compose)
POSTGRES_USER=nl2sql
POSTGRES_PASSWORD=nl2sql_secret
POSTGRES_DB=ecommerce

# Backend
BACKEND_PORT=8000
MAX_RETRIES=3

# Frontend
FRONTEND_PORT=3000
